{
  "name": "qr-scanner-pwa",
  "version": "1.0.0",
  "private": true,
  "description": "Fast, offline QR code scanner PWA. Scan with your camera or an image file.",
  "scripts": {
    "serve": "serve -l 5173 .",
    "test": "playwright test",
    "test:unit": "node --test \"tests/unit/**/*.test.mjs\"",
    "test:ui": "playwright test --ui",
    "test:fixtures": "node tests/fixtures/generate.mjs",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect --url=http://localhost:5173 --numberOfRuns=3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.55.0",
    "qrcode": "^1.5.4",
    "serve": "^14.2.5"
  }
}
